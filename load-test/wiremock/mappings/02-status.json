{
  "_comment": "AI 서버: GET /api/v1/status/{jobId} stub. baseline 측정 단순화를 위해 즉시 completed 반환 → 폴링 1회로 종료.",
  "request": {
    "method": "GET",
    "urlPathPattern": "/api/v1/status/[^/]+"
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "transformers": ["response-template"],
    "jsonBody": {
      "job_id": "{{request.path.[3]}}",
      "status": "completed"
    }
  }
}
